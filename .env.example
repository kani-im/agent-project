# Upbit API Keys
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# ── Trading Safety Controls ──────────────────────────────────────
# TRADING_MODE: dry_run (default) | live
#   dry_run — signals and risk checks run, but NO real orders are placed.
#   live    — orders are sent to the exchange.
TRADING_MODE=dry_run

# TRADING_ENABLED: true (default) | false
#   Set to false to immediately halt all order flow (kill switch).
TRADING_ENABLED=true

# ── Notifications (Telegram) ─────────────────────────────────────
# Enable in config/settings.toml ([notification] enabled = true)
# then provide your Telegram bot token and chat ID here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
